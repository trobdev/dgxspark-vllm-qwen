# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit your real token.

# Host directory where model weights are stored and bind-mounted into the container.
MODEL_PATH=/data/models

# HuggingFace access token, needed to download the gated NVFP4 checkpoint.
# Create one at https://huggingface.co/settings/tokens and accept the model
# license on the model's HuggingFace page first.
HF_TOKEN=hf_your_token_here
